<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.dotfiles.kuang</string>

    <key>ProgramArguments</key>
    <array>
        <string>__KUANG_BIN__</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>KUANG_ADDR</key>
        <string>:7117</string>
        <key>KUANG_ICE_ENDPOINT</key>
        <string>http://127.0.0.1:9119</string>
        <key>KUANG_CERTS_DIR</key>
        <string>__CERTS_DIR__</string>
        <key>PATH</key>
        <string>__PATH__</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/kuang.out.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/kuang.err.log</string>
</dict>
</plist>
