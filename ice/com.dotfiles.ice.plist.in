<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.dotfiles.ice</string>

    <key>ProgramArguments</key>
    <array>
        <string>__PYTHON3__</string>
        <string>-m</string>
        <string>ice.server</string>
        <string>--host</string>
        <string>127.0.0.1</string>
        <string>--port</string>
        <string>9119</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/ice.out.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/ice.err.log</string>
</dict>
</plist>
